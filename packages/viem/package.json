{
  "name": "@monad-crypto/viem",
  "version": "0.0.0",
  "description": "TypeScript Interface for Monad",
  "repository": {
    "type": "git",
    "url": "https://github.com/monad-developers/monad-ts.git",
    "directory": "packages/viem"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src/**/*.ts",
    "!**/*.test.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": ">=5.0.4",
    "viem": ">=2"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "viem": "2.45.1"
  }
}
